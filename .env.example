# === Telegram Bot ===
# Bot token from @BotFather (required for bot service)
TELEGRAM_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (required)
ALLOWED_UIDS=

# Optional: Telegram API credentials for local API server (>20MB files)
# Get from https://my.telegram.org
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# === NanoScribe Application ===
# See README.md §Environment Variables for full documentation.

# Root directory for all persistent data (default: /app/data)
# NANOSCRIBE_DATA_DIR=/app/data

# Path to built frontend SPA (default: /app/static)
# NANOSCRIBE_STATIC_DIR=/app/static

# Set to 1 to skip remote model checks/downloads (default: 0)
# NANOSCRIBE_OFFLINE=0

# Bearer token for the OpenAI-compatible endpoint (default: empty = no auth)
# NANOSCRIBE_API_KEY=

# Remote ASR endpoint URL — include /v1 prefix (e.g. https://api.openai.com/v1)
# NANOSCRIBE_REMOTE_ASR_URL=

# API key for the remote ASR provider
# NANOSCRIBE_REMOTE_ASR_API_KEY=

# Model ID for the remote ASR provider (default: whisper-1)
# NANOSCRIBE_REMOTE_ASR_MODEL=whisper-1

# Remote ASR request timeout in seconds (default: 900)
# NANOSCRIBE_REMOTE_ASR_TIMEOUT=900

# Keep models warm on GPU: 1=always, 0=never, empty=auto (default: empty)
# NANOSCRIBE_KEEP_MODELS_WARM=

# VAD chunking overrides (ms). Set to 0 for auto-detection.
# NANOSCRIBE_VAD_MAX_CHUNK_MS=0
# NANOSCRIBE_VAD_MERGE_GAP_MS=800
# NANOSCRIBE_VAD_CHUNK_BUFFER_MS=200
# NANOSCRIBE_VAD_MIN_CHUNK_MS=400

# Prevent HuggingFace downloads when set to 1 (default: 0)
# HF_HUB_OFFLINE=0

# CUDA memory allocator (default: expandable_segments:True)
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
