          "expected": "md5sum calculated",
          "observed": "cd95cf4203626793a0e867c886fc95b4"
        },
        {
          "action": "Upload via POST /api/memos with files[]=@/tmp/test_normalization_009.mp3",
          "expected": "201 with memo and job created",
          "observed": "201 response, memo_id=4e27316c-a507-4d5c-9775-b682e478ae83, source_filename=test_normalization_009.mp3"
        },
        {
          "action": "Check container: ls /app/data/memos/<memo_id>/source.original",
          "expected": "source.original exists",
          "observed": "source.original exists, 81837 bytes, permissions -rw-r--r--"
        },
        {
          "action": "Compute md5sum of container source.original",
          "expected": "Matches host upload md5sum",
          "observed": "cd95cf4203626793a0e867c886fc95b4 — identical to uploaded file"
        },
        {
          "action": "Check memo source_filename field",
          "expected": "Matches original filename",
          "observed": "source_filename = 'test_normalization_009.mp3' — matches"
        }
      ],
      "evidence": {
