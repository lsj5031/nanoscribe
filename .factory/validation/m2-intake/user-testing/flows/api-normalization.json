    "VAL-INTAKE-010": {
      "id": "VAL-INTAKE-010",
      "title": "ffmpeg normalizes audio to canonical WAV",
      "status": "pass",
      "steps": [
        {
          "action": "Upload 7 format files (mp3, wav, m4a, aac, webm, ogg, opus) via POST /api/memos",
          "expected": "All uploads succeed with memos created",
          "observed": "All 7 uploads succeeded, 7 memos created with status=queued"
        },
        {
          "action": "Run normalization manually on each memo via docker exec python",
          "expected": "All formats normalize successfully",
          "observed": "All 7 formats normalized without error"
        },
        {
          "action": "Run ffprobe on each normalized.wav",
          "expected": "PCM WAV, 16-bit, mono, 16kHz for all",
          "observed": "All 7: codec_name=pcm_s16le, sample_rate=16000, channels=1, bits_per_sample=16"
        }
      ],
      "evidence": {
